        return self.inject_entropy(diff)

    def analyze_drift(self, src):
        return openai.ChatCompletion.create(
            model="gpt-4o",
            messages=[
                {"role": "system", "content": "Analyze genetic code drift."},
                {"role": "user", "content": src}
            ]
