class ChronosMemory: def init(self, vault_path="chronos_memory.zst"): self.vault_path = vault_path self.vault = []

def log(self, user_input, model_output):
    entry = {
        "timestamp": datetime.utcnow().isoformat(),
        "user_input": user_input,
        "model_output": model_output,
        "hash": hashlib.sha256((user_input + model_output).encode()).hexdigest()
    }
    self.vault.append(entry)
    self._save_vault()

def _save_vault(self):
    compressed = zstd.ZstdCompressor().compress(json.dumps(self.vault).encode())
    with open(self.vault_path, "wb") as f:
        f.write(compressed)

def load_vault(self):
    if not os.path.exists(self.vault_path): return []
    with open(self.vault_path, "rb") as f:
        data = zstd.ZstdDecompressor().decompress(f.read())
        self.vault = json.loads(data.decode())
    return self.vault

